rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ============== CONTENT COLLECTIONS ==============
    // Public read, admin-only write
    
    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Featured Banners
    match /featuredBanners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Letters
    match /letters/{letterId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Lessons
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Quizzes
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Stickers
    match /stickers/{stickerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // App Strings
    match /appStrings/{stringId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ============== USER COLLECTIONS ==============
    
    // Users
    match /users/{userId} {
      // Users can read their own data
      // Admins can read all user data
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own document
      allow create: if isOwner(userId);
      
      // Users can update their own data, except role field
      allow update: if isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      
      // Only admins can update role or delete users
      allow update: if isAdmin();
      allow delete: if isAdmin();
      
      // User progress subcollection
      match /progress/{categoryId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
